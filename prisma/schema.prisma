generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum DocumentType {
  DPI
  LICENCIA
}

enum DeliveryStatus {
  SENT
  FAILED
}

enum AccountTokenType {
  VERIFY_EMAIL
  RESET_PASSWORD
}

enum ConsentType {
  TERMS
  PRIVACY
  ALERT_EMAILS
}

enum EmailCategory {
  VERIFICATION
  PASSWORD_RESET
  PASSWORD_CHANGED
  REMINDER
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         Role       @default(USER)
  createdAt    DateTime   @default(now())
  emailVerifiedAt DateTime?
  sessionVersion  Int        @default(0)
  mfaSecretEncrypted String?
  mfaEnabledAt       DateTime?
  documents    Document[]
  accountTokens AccountToken[]
  consents      ConsentRecord[]
  emailDeliveries EmailDelivery[]
  recoveryCodes  MfaRecoveryCode[]
}

model MfaRecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String    @unique
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, usedAt])
}

model AccountToken {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      AccountTokenType
  tokenHash String           @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, type])
  @@index([expiresAt])
}

model ConsentRecord {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ConsentType
  version   String
  ipAddress String?
  createdAt DateTime    @default(now())

  @@index([userId, type])
}

model EmailDelivery {
  id                String         @id @default(cuid())
  userId            String?
  user              User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  recipientEmail    String
  category          EmailCategory
  deliveryStatus    DeliveryStatus
  providerMessageId String?
  errorMessage      String?
  createdAt         DateTime       @default(now())

  @@index([createdAt])
  @@index([category, deliveryStatus])
}

model Document {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          DocumentType
  name          String
  expiryDate    DateTime           @db.Date
  createdAt     DateTime           @default(now())
  notifications NotificationLog[]

  @@index([userId])
  @@index([expiryDate])
}

model NotificationLog {
  id             String         @id @default(cuid())
  documentId     String
  document       Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  recipientEmail String
  statusLabel    String
  deliveryStatus DeliveryStatus
  reminderKey    String?        @unique
  errorMessage   String?
  sentAt         DateTime       @default(now())

  @@index([documentId])
  @@index([sentAt])
}
