# PostgreSQL creado en Coolify. No publiques este archivo con valores reales.
DATABASE_URL="postgresql://vigentegt:change-me@postgres:5432/vigentegt?schema=public"

# Usa al menos 32 caracteres aleatorios.
JWT_SECRET="replace-with-a-long-random-secret"
PUBLIC_APP_URL="https://vigente.example.com"
OBSERVABILITY_TOKEN="replace-with-a-separate-random-secret"
LEGAL_VERSION="2026-07-21"
PRIVACY_CONTACT="privacidad@example.com"
LOG_LEVEL="info"

# Esta cuenta se crea como administrador durante el primer arranque.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-with-a-strong-password"

PORT="3000"
NODE_ENV="production"
TZ="America/Guatemala"

# Opcional: activa correos reales y recordatorios automáticos.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="smtp-user"
SMTP_PASSWORD="smtp-password"
MAIL_FROM="Vigente GT <avisos@example.com>"

# Solo para verificar una restauración en una base aislada; nunca apuntes a producción.
VERIFY_DATABASE_URL="postgresql://vigentegt:change-me@restored-postgres:5432/vigentegt?schema=public"
